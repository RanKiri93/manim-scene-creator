{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manim Timeline",
  "version": "0.0.0",
  "identifier": "com.manimstuff.manim-timeline",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Manim Timeline",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/icon.ico"]
  },
  "plugins": {}
}
